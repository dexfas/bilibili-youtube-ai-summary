{
  "manifest_version": 3,
  "name": "auto-tran-video Browser Helper",
  "version": "0.4.0",
  "description": "Select videos on Bilibili, BewlyCat, and YouTube, then send them to the local auto-tran-video service.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*.bilibili.com/*",
        "https://*.bilibili.com/*",
        "http://*.youtube.com/*",
        "https://*.youtube.com/*",
        "http://youtu.be/*",
        "https://youtu.be/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_title": "auto-tran-video"
  }
}
